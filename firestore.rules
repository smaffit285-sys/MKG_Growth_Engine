rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isStaffUser() {
      return isAuth() && exists(/databases/$(database)/documents/staffUsers/$(request.auth.uid));
    }

    function staffRole() {
      return get(/databases/$(database)/documents/staffUsers/$(request.auth.uid)).data.role;
    }

    function isOwnerOrAdmin() {
      return isStaffUser() && staffRole() in ['owner', 'admin'];
    }

    function isOperator() {
      return isStaffUser() && staffRole() in ['owner', 'admin', 'staff', 'marketing', 'readonly'];
    }

    function isWriter() {
      return isStaffUser() && staffRole() in ['owner', 'admin', 'staff', 'marketing'];
    }

    match /staffUsers/{userId} {
      allow read: if isOwnerOrAdmin() || (isAuth() && request.auth.uid == userId);
      allow create, update, delete: if isOwnerOrAdmin();
    }

    match /customers/{customerId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isWriter();
    }

    match /referrals/{referralId} {
      allow create: if true;
      allow read, update, delete: if isWriter();
    }

    match /rewardLedger/{ledgerId} {
      allow read: if isOperator();
      allow create: if true;
      allow update, delete: if isOwnerOrAdmin();
    }

    match /reviewSubmissions/{reviewId} {
      allow create: if true;
      allow read, update, delete: if isWriter();
    }

    match /ugcSubmissions/{ugcId} {
      allow create: if true;
      allow read, update, delete: if isWriter();
    }

    match /commercialAccounts/{accountId} {
      allow read: if isOperator();
      allow create, update, delete: if isWriter();
    }

    match /customerEvents/{eventId} {
      allow read: if isOperator();
      allow create: if true;
      allow update, delete: if isOwnerOrAdmin();
    }

    match /leadAlerts/{alertId} {
      allow create: if true;
      allow read, update, delete: if isWriter();
    }

    match /contentPipeline/{contentId} {
      allow read: if isOperator();
      allow create, update, delete: if isWriter();
    }

    match /proofAssets/{assetId} {
      allow read: if isOperator();
      allow create, update, delete: if isWriter();
    }

    match /trainingSessions/{sessionId} {
      allow read: if isOperator();
      allow create: if isWriter();
      allow update, delete: if isOwnerOrAdmin();
    }

    match /sharpeningSessions/{sessionId} {
      allow read: if isOperator();
      allow create: if isWriter();
      allow update, delete: if isOwnerOrAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isOperator();
      allow create, update: if isWriter();
      allow delete: if isOwnerOrAdmin();
    }

    match /settings/{settingId} {
      allow read: if isOperator();
      allow write: if isOwnerOrAdmin();
    }

    match /analytics/{docId} {
      allow read: if isOperator();
      allow write: if isOwnerOrAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
